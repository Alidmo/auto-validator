# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one provider. Options ranked by cost:
#
#   gemini           FREE — 250 req/day, no billing required
#   ollama           FREE — runs fully local, no internet
#   openai-compatible FREE/CHEAP — Groq (free tier), LM Studio (local), Together.ai
#   openai           PAID — GPT-4o via OpenAI API
#   anthropic        PAID — Claude via Anthropic API
#
# NOTE: Claude Pro / Gemini Advanced / ChatGPT Plus are consumer chat products.
#       They do NOT include API access. Use the developer APIs below.

LLM_PROVIDER=gemini

# ── Gemini (FREE) ─────────────────────────────────────────────────────────────
# Get your key in ~2 minutes at: https://aistudio.google.com/apikey
# Free tier: 250 requests/day, 10 requests/minute
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Ollama (LOCAL, FREE) ──────────────────────────────────────────────────────
# Install: https://ollama.com  then run: ollama pull llama3
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── OpenAI-Compatible (FREE/CHEAP — Groq, LM Studio, Together.ai, etc.) ──────
# Works with any service implementing the OpenAI Chat Completions API.
# Groq example (free tier, very fast):
# LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPATIBLE_API_KEY=gsk_your_groq_key_here
# OPENAI_COMPATIBLE_MODEL=llama-3.3-70b-versatile
#
# LM Studio example (fully local):
# LLM_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_API_KEY=none
# OPENAI_COMPATIBLE_MODEL=your-loaded-model-name

# ── OpenAI (PAID) ─────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Anthropic Claude (PAID) ───────────────────────────────────────────────────
# Requires: pip install anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-6

# ── General ───────────────────────────────────────────────────────────────────
# DRY_RUN=true: full pipeline runs with no external API calls (safe default)
DRY_RUN=true

# ── Image Generation (DALL-E 3) ───────────────────────────────────────────────
# Requires OPENAI_API_KEY (paid). Set true to generate actual images.
DALLE_ENABLED=false

# ── Google Docs ───────────────────────────────────────────────────────────────
# Service account JSON from Google Cloud Console (for writing docs)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# ── Tally.so (Quiz Builder) ───────────────────────────────────────────────────
TALLY_API_KEY=

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ── State Storage ─────────────────────────────────────────────────────────────
# Default: local JSON files at ~/.auto-validator/projects/
# Set both to switch to Supabase (Sprint 4)
SUPABASE_URL=
SUPABASE_KEY=

# ── Paths (optional overrides) ────────────────────────────────────────────────
# OUTPUT_DIR=output
# DATA_DIR=~/.auto-validator/projects

# ── CVR Smart Logic Thresholds ────────────────────────────────────────────────
CVR_VALIDATED_THRESHOLD=0.20
CVR_REFINEMENT_THRESHOLD=0.05

# ── Validation Loop Guards ────────────────────────────────────────────────────
MAX_REFINEMENT_RETRIES=3
MIN_PAIN_SCORE=5

# ── Webhook Server ────────────────────────────────────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
